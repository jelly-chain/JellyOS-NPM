{
  "name": "@jellyos/agent",
  "version": "0.1.5",
  "description": "JellyOS — standalone AI trading agent. Runs locally, no server required.",
  "author": "JellyChain",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "jellyos": "./bin/jellyagent",
    "jellyagent": "./bin/jellyagent",
    "jellyos-mcp": "./bin/jellyos-mcp"
  },
  "scripts": {
    "build": "npx tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "tsx": "^4.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.29",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "trading",
    "blockchain",
    "terminal",
    "cli",
    "jellyos"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "!dist/**/*.map"
  ]
}
